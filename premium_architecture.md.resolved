        FG["UpgradePrompt / Feature Check<br/>Hides UI for free users"]
    end
    
    subgraph "Layer 2: API Middleware"
        AM["checkHabitLimit()<br/>checkGoalLimit()<br/>checkFeatureAccess()"]
    end
    
