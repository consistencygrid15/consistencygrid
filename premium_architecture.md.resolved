### 1.3 Razorpay Order Creation

```javascript
// POST /api/payment/create-order — Already implemented
// File: src/app/api/payment/create-order/route.js

export async function POST(req) {
    // 1. Authenticate user (NextAuth session)
    const session = await getServerSession(authOptions);
    
    // 2. Validate plan & eligibility
    const { planId, useLaunchPrice = true } = await req.json();
    const plan = getPlan(planId);              // from payment-config.js
    const canUpgrade = canUpgradeToPlan(currentPlan, planId);
    
    // 3. Calculate amount (paise)
    const amount = getPlanAmount(planId, useLaunchPrice);
    
    // 4. Create Razorpay order
    const provider = getProviderInstance();     // Singleton RazorpayProvider
    const order = await provider.createOrder({
        amount,
        currency: plan.currency,
        metadata: { userId, userEmail, planId }
    });
    
    // 5. Track in database
    await prisma.paymentTransaction.create({
        data: {
            userId, provider: 'razorpay',
            providerOrderId: order.orderId,
            amount, currency: plan.currency,
            plan: planId, status: 'created'
        }
    });
    
    return { orderId, amount, currency, provider: 'razorpay' };
}
```

### 1.4 Secure Payment Verification

```javascript
// POST /api/payment/verify — Already implemented
// File: src/app/api/payment/verify/route.js

// CRITICAL: Server-side HMAC-SHA256 verification
const body = `${razorpay_order_id}|${razorpay_payment_id}`;
const expectedSignature = crypto
    .createHmac('sha256', this.keySecret)
    .update(body)
    .digest('hex');

// Constant-time comparison prevents timing attacks
const isValid = crypto.timingSafeEqual(
    Buffer.from(expectedSignature, 'hex'),
    Buffer.from(razorpay_signature, 'hex')
);

// Double-check: fetch payment from Razorpay API
const paymentDetails = await this.getPaymentDetails(razorpay_payment_id);
if (paymentDetails.status !== 'captured') return false;
```

### 1.5 Webhook Handler (Async Backup)

```javascript
// POST /api/payment/webhook — Already implemented (395 lines)
// File: src/app/api/payment/webhook/route.js
// NO AUTH REQUIRED — called by Razorpay servers

// Events handled:
// ✅ payment.captured     → Update user plan + send email
// ✅ payment.failed       → Log failure
// ✅ subscription.charged → Extend subscription dates
// ✅ subscription.cancelled → Downgrade to free
// ✅ refund.processed     → Handle refund + downgrade

// Webhook signature verification:
const isValid = await provider.verifyWebhook(rawBody, signature);
// Uses HMAC-SHA256 with RAZORPAY_WEBHOOK_SECRET
```

### 1.6 Database Updates on Payment Success

```javascript
// Subscription date calculation (in verify route + webhook):
const now = new Date();
let subscriptionEndDate;

if (plan === 'lifetime') {
    subscriptionEndDate = new Date(now.getFullYear() + 100, ...);
} else if (plan === 'pro_yearly') {
    subscriptionEndDate = new Date(now.getFullYear() + 1, ...);
} else if (plan === 'pro_monthly') {
    subscriptionEndDate = new Date(now.getFullYear(), now.getMonth() + 1, ...);
}

await prisma.user.update({
    where: { id: user.id },
    data: {
        plan: transaction.plan,           // "pro_monthly" | "pro_yearly" | "lifetime"
        subscriptionStatus: 'active',
        subscriptionStartDate: now,
        subscriptionEndDate,
        paymentProvider: 'razorpay'
    }
});
```

