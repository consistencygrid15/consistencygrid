### 3.3 PaymentCheckout Flow (Existing)

```javascript
// File: src/components/payment/PaymentCheckout.js (271 lines)

function PaymentCheckout({ planId, planName, amount, onSuccess, onError }) {
    // 1. Platform check — hide in Android
    const [showPaymentUI, setShowPaymentUI] = useState(true);
    useEffect(() => { setShowPaymentUI(shouldShowPaymentUI()); }, []);

    // 2. Load Razorpay SDK dynamically
    const loadPaymentSDK = (scriptUrl) => {
        return new Promise((resolve, reject) => {
            const script = document.createElement('script');
            script.src = scriptUrl;  // https://checkout.razorpay.com/v1/checkout.js
            document.body.appendChild(script);
        });
    };

    // 3. Create order on backend
    const handlePayment = async () => {
        const res = await fetch('/api/payment/create-order', {
            method: 'POST',
            body: JSON.stringify({ planId, useLaunchPrice: true })
        });
        const data = await res.json();
        handleRazorpayCheckout(data);
    };

    // 4. Open Razorpay checkout
    const handleRazorpayCheckout = (orderData) => {
        const options = {
            key: process.env.NEXT_PUBLIC_RAZORPAY_KEY_ID,
            amount: orderData.order.amount,
            order_id: orderData.order.orderId,
            handler: async (response) => {
                // 5. Verify on backend
                await verifyPayment(response);
            }
        };
        const rzp = new window.Razorpay(options);
        rzp.open();
    };

    // 6. If Android — show "Continue on Website" instead
    if (!showPaymentUI) {
        return <AndroidUpgradeMessage />;
    }
}
```

