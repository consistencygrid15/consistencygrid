```

### 5.2 API-Level Access Control (Existing)

From [subscription-middleware.js](file:///d:/startup/consistencygrid/src/lib/subscription-middleware.js):

```javascript
// Habit creation limit check
export async function checkHabitLimit(userId) {
    const user = await getUserSubscription(userId);
    const isFreeUser = user.plan === "free" || !user.plan;
    const habitLimit = 3;
    
    if (isFreeUser && user._count.habits >= habitLimit) {
        return {
            canCreate: false,
            currentCount: user._count.habits,
            limit: habitLimit,
            message: "You've reached the habit limit (3) on the Free plan."
        };
    }
    return { canCreate: true };
}

// Generic feature gating
export async function checkFeatureAccess(userId, feature) {
    const proOnlyFeatures = [
        "analytics", "ai_suggestions", "export",
        "cloud_sync", "reminders"
    ];
    
    if (isFreeUser && proOnlyFeatures.includes(feature)) {
        return { allowed: false, reason: "Requires Pro plan" };
    }
    return { allowed: true };
}

// Subscription expiry validation
export async function isSubscriptionActive(userId) {
    if (user.subscriptionStatus === "active") {
        if (user.subscriptionEndDate) {
            return new Date() < new Date(user.subscriptionEndDate);
        }
        return true;
    }
    // Check trial
    if (user.trialEndDate) {
        return new Date() < new Date(user.trialEndDate);
    }
    return false;
}
```

### 5.3 Frontend Feature Access Map (Existing)

From [subscription-utils.js](file:///d:/startup/consistencygrid/src/lib/subscription-utils.js):

```javascript
export function getFeatureAccess(user) {
    const isFreeUser = user.plan === "free" || !user.plan;
    
    return {
        habits:        { allowed: true,  limit: isFreeUser ? 3 : null },
        goals:         { allowed: true,  limit: isFreeUser ? 3 : null },
        history:       { allowed: true,  maxDaysBack: isFreeUser ? 7 : null },
        analytics:     { allowed: !isFreeUser },
        themes:        { allowed: true,  limit: isFreeUser ? 1 : null },
        export:        { allowed: !isFreeUser },
        aiSuggestions: { allowed: !isFreeUser },
        cloudSync:     { allowed: !isFreeUser },
        reminders:     { allowed: !isFreeUser },
    };
}
```

### 5.4 API Usage Pattern

```javascript
// Example: Habit creation API route using the protection

import { checkHabitLimit, SubscriptionErrors } from '@/lib/subscription-middleware';

export async function POST(req) {
    const session = await getUniversalSession();
    const userId = session.user.id;
    
    // ✅ Check subscription limit BEFORE creating
    const limitCheck = await checkHabitLimit(userId);
    if (!limitCheck.canCreate) {
        return NextResponse.json(
            SubscriptionErrors.HABIT_LIMIT_REACHED,
            { status: 403 }
        );
    }
    
    // Proceed with creation...
    const habit = await prisma.habit.create({ ... });
}
```

