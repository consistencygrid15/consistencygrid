generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String               @id @default(cuid())
  name                    String?
  email                   String               @unique
  password                String?
  image                   String?
  publicToken             String               @unique
  onboarded               Boolean              @default(false)
  resetToken              String?              @unique
  resetTokenExpiry        DateTime?
  plan                    String               @default("free")
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  subscriptionStatus      String?
  subscriptionStartDate   DateTime?
  subscriptionEndDate     DateTime?
  trialEndDate            DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  emailVerified           DateTime?
  paymentProvider         String?
  verificationToken       String?              @unique
  verificationTokenExpiry DateTime?
  consentPreferences      ConsentPreference?
  deviceTokens            DeviceToken[]
  goals                   Goal[]
  habits                  Habit[]
  habitLogs               HabitLog[]
  milestones              Milestone[]
  paymentTransactions     PaymentTransaction[]
  reminders               Reminder[]
  settings                WallpaperSettings?
}

model DeviceToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  deviceType String   @default("android")
  timezone   String   @default("UTC")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timezone])
}

model WallpaperSettings {
  id                  String    @id @default(cuid())
  userId              String    @unique
  dob                 DateTime
  lifeExpectancyYears Int       @default(80)
  theme               String    @default("dark-minimal")
  width               Int       @default(1080)
  height              Int       @default(2400)
  showLifeGrid        Boolean   @default(true)
  showYearGrid        Boolean   @default(true)
  showAgeStats        Boolean   @default(true)
  showQuote           Boolean   @default(false)
  quote               String?
  goalEnabled         Boolean   @default(false)
  goalTitle           String?
  goalStartDate       DateTime?
  goalDurationDays    Int?
  goalUnit            String?
  yearGridMode        String    @default("weeks")
  wallpaperType       String    @default("lockscreen")
  showMissedDays      Boolean   @default(false)
  showHabitLayer      Boolean   @default(false)
  showLegend          Boolean   @default(false)
  updatedAt           DateTime  @updatedAt
  customBackgroundUrl String?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Habit {
  id            String     @id @default(cuid())
  userId        String
  title         String
  scheduledTime String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs          HabitLog[]

  @@index([userId])
  @@index([userId, isActive])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  userId    String
  date      DateTime
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([habitId, date])
}

model Reminder {
  id                  String   @id @default(cuid())
  userId              String
  title               String
  description         String?
  startDate           DateTime
  endDate             DateTime
  startTime           String?
  endTime             String?
  isFullDay           Boolean  @default(true)
  markerType          String   @default("dot")
  markerColor         String   @default("#ff7a00")
  markerIcon          String?
  priority            Int      @default(1)
  isImportant         Boolean  @default(false)
  enableNotifications Boolean  @default(true)
  notifyOnStart       Boolean  @default(true)
  notifyDaily         Boolean  @default(false)
  isRecurring         Boolean  @default(false)
  recurrenceRule      String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@index([userId, endDate])
}

model Goal {
  id             String    @id @default(cuid())
  userId         String
  title          String
  category       String    @default("General")
  description    String?
  progress       Int       @default(0)
  targetDeadline DateTime?
  age            Int?
  isCompleted    Boolean   @default(false)
  isPinned       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subGoals       SubGoal[]

  @@index([userId])
  @@index([userId, isCompleted])
  @@index([userId, isPinned])
}

model SubGoal {
  id          String   @id @default(cuid())
  goalId      String
  title       String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Milestone {
  id          String   @id @default(cuid())
  userId      String
  title       String
  age         Int
  status      String   @default("future")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentTransaction {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerOrderId   String   @unique
  providerPaymentId String?  @unique
  amount            Int
  currency          String   @default("INR")
  plan              String
  status            String
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerOrderId])
  @@index([status])
}

model ConsentPreference {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  data_processing        Boolean  @default(true)
  analytics              Boolean  @default(true)
  marketing_emails       Boolean  @default(false)
  performance_monitoring Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
